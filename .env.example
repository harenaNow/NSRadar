# ===== 必填 =====
# Telegram Bot Token（向 @BotFather 申请）
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# 管理员 Telegram 用户 ID（可多个，逗号分隔）。获取方式：向 @userinfobot 发消息
ADMIN_IDS=123456789

# ===== 可选（以下为默认值，按需修改）=====
# 是否允许非管理员使用机器人（true/false），默认仅管理员可用
ALLOW_PUBLIC=false

# NodeSeek RSS 订阅源（可多个，逗号分隔）
RSS_FEEDS=https://www.nodeseek.com/rss.xml

# RSS 检查间隔（秒），最小 15
CHECK_INTERVAL_SEC=60

# SQLite 数据库路径
DB_PATH=./data/nsradar.db

# 抓取 RSS 时使用的 User-Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# NodeSeek Cookie（可选；遇到反爬/需登录内容时填写，形如 "session=xxx; ...)
RSS_COOKIE=

# 仅推送最近 N 小时内的帖子，0 表示不限制（按 pubDate 过滤）
MAX_AGE_HOURS=0

# 日志级别：debug / info / warn / error
LOG_LEVEL=info
