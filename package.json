{
  "name": "nsradar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "NodeSeek RSS monitor with keyword filtering and Telegram bot push management",
  "main": "src/main.js",
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/main.js",
    "dev": "node --watch --disable-warning=ExperimentalWarning src/main.js",
    "check": "node --disable-warning=ExperimentalWarning src/main.js --once"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "grammy": "^1.44.0",
    "rss-parser": "^3.13.0"
  }
}
